{
  "description": "Backup hooks for claude-session-backup plugin. Runs csb backup on PreCompact (before lossy compaction) and SessionEnd (on exit).",
  "hooks": {
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/backup-hook.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/backup-hook.py"
          }
        ]
      }
    ]
  }
}
